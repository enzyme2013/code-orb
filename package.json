{
  "name": "code-orb",
  "private": true,
  "version": "0.2.0",
  "description": "CLI-first coding agent with a future desktop path.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm exec tsc --outDir dist",
    "cli:run": "node --import tsx apps/cli/src/main.ts",
    "benchmark:failing-test-fix": "CODE_ORB_AUTO_APPROVE=1 node --import tsx scripts/run-failing-test-fix-benchmark.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
